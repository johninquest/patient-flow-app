# ===========================================
# PATIENT FLOW DOCKER ORCHESTRATION ENVIRONMENT
# ===========================================
# Copy this file to .env at the repo root and fill in the values.
# This file is used ONLY by Docker Compose to pass shared configuration
# into the API and database containers. It must not contain client build-time
# variables or API-only runtime variables (those belong in api/.env).

# ---------- DATABASE ----------
# PostgreSQL connection string used by the API container.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://patientflow:patientflow_dev_password@postgres:5432/patientflow

# ---------- AUTHENTICATION ----------
# Secret key for Better Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=your_super_secret_key_here

# ---------- URLS ----------
# Publicly accessible service URLs.
API_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173

# ---------- GOOGLE OAUTH ----------
# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret