# ===========================================
# PATIENT FLOW ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in the values

# ---------- DATABASE ----------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For Docker Compose (recommended):
DATABASE_URL=postgresql://patientflow:patientflow_dev_password@postgres:5432/patientflow
# For local development without Docker:
# DATABASE_URL=postgresql://patientflow:patientflow_dev_password@localhost:5432/patientflow

# ---------- AUTHENTICATION ----------
# Secret key for JWT tokens (generate with: openssl rand -base64 32)
AUTH_SECRET=your_super_secret_key_here

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ---------- URLS (Production) ----------
# API URL (accessible from browser)
API_URL=https://api.patientflow.app

# Client URL (accessible from browser)
CLIENT_URL=https://app.patientflow.app

# ---------- URLS (Development) -----------
# Uncomment these for local development
# API_URL=http://localhost:3000
# CLIENT_URL=http://localhost:5173